<li>
  <%= toggle_attendance_button(@event || session.event, session) %>
  <h4><%= link_to session.title, session %></h4> 
  <div class="presenter">by <%= session.presenters.map {|p| link_to p.name, p }.to_sentence.html_safe %>
    <% edit(session) do %>
      <span class="edit-session">(<%= link_to 'edit', edit_session_path(session) %>)</span>
    <% end %>
  </div>
</li>
